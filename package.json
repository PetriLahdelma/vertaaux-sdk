{
  "name": "vertaaux-sdk",
  "version": "2.0.0",
  "description": "Official TypeScript SDK for VertaaUX.ai — AI-powered UX and accessibility auditing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vertaaux",
    "accessibility",
    "a11y",
    "wcag",
    "ux",
    "audit",
    "testing",
    "ai",
    "sdk",
    "api",
    "ci",
    "automation"
  ],
  "author": "Petri Lahdelma <mail@digitaltableteur.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PetriLahdelma/vertaaux-sdk.git"
  },
  "homepage": "https://vertaaux.ai",
  "bugs": {
    "url": "https://github.com/PetriLahdelma/vertaaux-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
