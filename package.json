{
  "name": "vertaaux-sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for VertaaUX.ai — AI-powered UX and accessibility auditing",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vertaaux",
    "accessibility",
    "a11y",
    "wcag",
    "ux",
    "audit",
    "testing",
    "ai",
    "sdk",
    "api",
    "ci",
    "automation"
  ],
  "author": "Petri Lahdelma <mail@digitaltableteur.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PetriLahdelma/vertaaux-sdk.git"
  },
  "homepage": "https://vertaaux.ai",
  "bugs": {
    "url": "https://github.com/PetriLahdelma/vertaaux-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
